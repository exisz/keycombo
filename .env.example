# Google Analytics — leave empty to disable
NEXT_PUBLIC_GA_ID=

# Google AdSense — leave empty to disable (e.g. ca-pub-1234567890)
NEXT_PUBLIC_ADSENSE_ID=

# Vercel Analytics + Speed Insights — set to "true" to enable
NEXT_PUBLIC_VERCEL_ANALYTICS=true

# --- Turso/Prisma (only for sites that need a database) ---
# These are auto-injected by Vercel when Turso integration is connected.
# For local dev, leave empty and use LOCAL_DATABASE_URL instead.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local SQLite for Prisma CLI (migrate dev, db push)
LOCAL_DATABASE_URL="file:./prisma/dev.db"
