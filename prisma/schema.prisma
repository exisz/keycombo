// Prisma schema for Starmap sites
// Provider: sqlite (Turso via @prisma/adapter-libsql at runtime)
// Modify this schema per site — this is a starting template

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

